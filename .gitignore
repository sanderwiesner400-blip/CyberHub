-- Funktion zum Wechseln der Kategorien
local function SwitchTab(tabName)
    ContentTitle.Text = tabName
    for _, item in pairs(CurrentContent) do
        if item.Category == tabName then
            item.Frame.Visible = true
        else
            item.Frame.Visible = false
        end
    end
end

-- Klick-Events für Kategorien verbinden
CatMain.MouseButton1Click:Connect(function() SwitchTab("Main") end)
CatVisuals.MouseButton1Click:Connect(function() SwitchTab("Visuals") end)
CatWorld.MouseButton1Click:Connect(function() SwitchTab("World") end)

-- Standardmäßig den Main-Tab anzeigen
